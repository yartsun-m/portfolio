      property="og:description"
      content="Backend & AI developer building FastAPI apps, PostgreSQL systems, and ML-powered tools. HAW Hamburg student open to Werkstudent roles."
    />
    <meta property="og:url" content="https://github.com/yartsun-m/portfolio" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Mykhailo Yartsun | Backend & AI Developer" />
