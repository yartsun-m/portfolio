<!doctype html>
<html lang="en">
  <head>
    <script type="module">import { injectIntoGlobalHook } from "/@react-refresh";
injectIntoGlobalHook(window);
window.$RefreshReg$ = () => {};
window.$RefreshSig$ = () => (type) => type;</script>

    <script type="module" src="/@vite/client"></script>

    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mykhailo Yartsun | Backend & AI Developer</title>
    <meta
      name="description"
      content="Information Engineering student at HAW Hamburg. Backend developer specializing in Python, FastAPI, PostgreSQL, Java, and AI/ML. Open to Werkstudent and internship roles in Hamburg, Germany."
    />
    <meta name="author" content="Mykhailo Yartsun" />
    <meta
      name="keywords"
      content="Mykhailo Yartsun, backend developer, software engineer, FastAPI, Python, PostgreSQL, AI, machine learning, Hamburg, Werkstudent, internship, portfolio"
    />
    <link rel="canonical" href="https://github.com/yartsun-m/portfolio" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Mykhailo Yartsun | Backend & AI Developer" />
