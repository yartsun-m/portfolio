# Formspree contact form — required for "Send Message" to work
# 1. Sign up at https://formspree.io
# 2. Create a new form (email: yartsun.m@gmail.com)
# 3. Copy only the form ID (the part after /f/), e.g. xzdlyape — not the full URL
# 4. Paste it below and restart the dev server

VITE_FORMSPREE_FORM_ID=xzdlyape

# Optional override — full endpoint URL instead of form ID above
# VITE_CONTACT_FORM_URL=https://formspree.io/f/YOUR_FORM_ID
